+# -*- coding: utf-8 -*-
+"""HYDRA V3 — root entry point (shim).
+
+Forwards to engine.v3.main_v3 with a portable PYTHONPATH so this works
+both inside Docker (/app) and on a developer laptop.
+"""
+from __future__ import annotations
+import os
+import sys
+from pathlib import Path
+
+# Add project root to PYTHONPATH so all 5 brain packages are importable.
+ROOT = Path(__file__).resolve().parent
+sys.path.insert(0, str(ROOT))
+
+# Honour Docker's /app convention if it exists (for Hostinger compatibility).
+if os.path.isdir("/app") and "/app" not in sys.path:
+    sys.path.insert(0, "/app")
+
+# Now hand off to the actual loop.
+from engine.v3 import main_v3  # noqa: F401  (executes the loop on import)
